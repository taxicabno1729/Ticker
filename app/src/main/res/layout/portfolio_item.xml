<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="2dp"
    app:cardBackgroundColor="@android:color/transparent"
    app:cardCornerRadius="0dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground">

        <!-- Token Icon -->
        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/circle_placeholder">

            <TextView
                android:id="@+id/token_icon_text"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/onSurface" />
        </FrameLayout>

        <!-- Symbol + Name -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/token_symbol"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.LiveTicker.TitleMedium"
                tools:text="ETH" />

            <TextView
                android:id="@+id/token_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                android:textColor="@color/onSurfaceVariant"
                tools:text="Ethereum" />

            <TextView
                android:id="@+id/token_chain"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                android:textColor="@color/onSurfaceVariant"
                android:visibility="gone"
                tools:text="Polygon"
                tools:visibility="visible" />
        </LinearLayout>

        <!-- Balance + Price -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/token_balance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.LiveTicker.BodyMedium"
                android:fontFamily="monospace"
                android:textColor="@color/onSurface"
                tools:text="1.2345" />

            <TextView
                android:id="@+id/token_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                android:textColor="@color/onSurfaceVariant"
                android:fontFamily="monospace"
                tools:text="$1,800.00" />
        </LinearLayout>

        <!-- Total USD Value -->
        <TextView
            android:id="@+id/token_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:textAppearance="@style/TextAppearance.LiveTicker.TitleMedium"
            android:fontFamily="monospace"
            android:minWidth="80dp"
            android:gravity="end"
            tools:text="$2,222.00" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
